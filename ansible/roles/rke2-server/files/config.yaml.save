# RKE2 Server Configuration
# https://docs.rke2.io/install/configuration

write-kubeconfig-mode: "0644"

# Cluster token - all nodes must share this
 token: "{{RKE2_TOKEN}}"

# TLS SANs for HA - add load balancer IP/hostname
tls-san:
  # - "k8s.example.com"
  # - "192.168.1.100"

# Disable default CNI (using Cilium instead)
ingress-controller: none
disable-kube-proxy: true

cni: cilium

# Network CIDRs
cluster-cidr: "10.42.0.0/16"
service-cidr: "10.43.0.0/16"

# For HA: non-bootstrap servers need this
# server: https://<first-server-or-lb>:9345
