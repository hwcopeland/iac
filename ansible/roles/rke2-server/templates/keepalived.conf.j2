global_defs {
  enable_script_security
}

vrrp_script check_apiserver {
  script "/usr/local/bin/check_apiserver.sh"
  interval 3
  weight -2
  fall 10
  rise 2
}

vrrp_instance RKE2_VIP {
  state {{ 'MASTER' if rke2_ha_master | default(false) else 'BACKUP' }}
  interface enp2s0f1
  virtual_router_id 51
  priority {{ rke2_ha_priority | default(100) }}
  advert_int 1

  authentication {
    auth_type PASS
    auth_pass {{ rke2_ha_password | default('rke2ha') }}
  }

  virtual_ipaddress {
    10.41.0.100/24
  }

  track_script {
    check_apiserver
  }
}
