FROM python:3.12-slim

# Audio + ML runtime deps
# - libpulse0: PulseAudio client lib so PortAudio can talk to the host's
#   pipewire-pulse socket (the userspace path — no /dev/snd needed).
# - libportaudio2: backs sounddevice
# - libsndfile1, ffmpeg: WAV decode for the chatterbox output
# - libgomp1: silero-vad onnx runtime
# - curl, gnupg, nodejs, npm: install the Anthropic `claude` CLI which
#   is the brain. We use it with ANTHROPIC_API_KEY (API mode) — the
#   subscription OAuth flow doesn't work cleanly in a headless pod.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpulse0 libportaudio2 libsndfile1 libgomp1 ffmpeg ca-certificates \
    libasound2-plugins \
    curl gnupg git \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g @anthropic-ai/claude-code \
    && curl -fsSL -o /usr/local/bin/kubectl \
       "https://dl.k8s.io/release/v1.31.2/bin/linux/amd64/kubectl" \
    && chmod +x /usr/local/bin/kubectl \
    && rm -rf /var/lib/apt/lists/*

# Vizio TV control (pyvizio) + LAN Chromecast (pychromecast).
RUN pip install --no-cache-dir pyvizio==0.1.64 pychromecast==14.0.10

# Route ALSA through the pulse plugin → pipewire-pulse on the host.
# Debian's libportaudio2 only ships ALSA + OSS backends (no native pulse
# compiled in), so ALSA→pulse via this plugin is the only path for
# sounddevice/PortAudio to see Yeti audio without /dev/snd.
RUN printf 'pcm.!default { type pulse }\nctl.!default { type pulse }\n' \
    > /etc/asound.conf

# openwakeword 0.6.0 declares tflite-runtime as a hard Linux dep but it
# has no Python 3.12 wheel. We only use the ONNX inference framework, so
# install openwakeword with --no-deps and bring its real transitive deps
# (minus tflite) in by hand.
RUN pip install --no-cache-dir --no-deps openwakeword==0.6.0 \
 && pip install --no-cache-dir \
    sounddevice==0.4.7 \
    scipy numpy requests tqdm scikit-learn \
    soco==0.30.4 \
    silero-vad onnxruntime \
 && python -c "import openwakeword.utils; openwakeword.utils.download_models()"

ENV XDG_RUNTIME_DIR=/run/user/1000 \
    PULSE_SERVER=unix:/run/user/1000/pulse/native \
    PYTHONUNBUFFERED=1

WORKDIR /app
