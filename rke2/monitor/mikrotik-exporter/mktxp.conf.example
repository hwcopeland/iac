# mktxp per-router config — EXAMPLE / DOCUMENTATION ONLY.
#
# The runtime config is rendered by external-secret-mktxp.yaml into the
# Secret `mktxp-credentials` (key: mktxp.conf), with the real password
# pulled from Bitwarden. This .example file exists so the structure of
# the config is reviewable in git without leaking secrets.
#
# To change the structure (add a router, toggle a metric):
#   1. Edit this file.
#   2. Mirror the change in the `template` block of
#      external-secret-mktxp.yaml.
#   3. kubectl rollout restart deploy/mktxp-exporter -n monitor

[CCR-2004]
    hostname = 10.0.0.1
    username = mktxp_user
    password = <REDACTED-RENDERED-FROM-BITWARDEN>

    bgp = True
    poe = False
    dns = True
    routing_stats = True
    connections = True
    connection_stats = False

# [cAP] section intentionally removed 2026-05-23.
# The cAP at 10.0.0.254 is managed by CAPsMAN running on CCR-2004. CAPsMAN
# already exposes everything we'd scrape directly (wireless clients, signal
# strength, rx/tx bytes, per-radio registrations, cAP version + identity)
# via mktxp_capsman_* metrics on the controller. Scraping the cAP directly
# was architecturally wrong and burned auth attempts every 30s.
# If a future cAP is ever standalone (no CAPsMAN), restore a [cAP-N] block
# and ensure mktxp_user exists locally on that device.

[default]
    enabled = True
    hostname = localhost
    port = 8728
    username = username
    password = password
    credentials_file = ""

    # Plaintext API on port 8728. Acceptable here because:
    # - mktxp_user is a read-only RouterOS user (group: read),
    # - traffic is pod -> node -> router on a private LAN,
    # - operator explicitly opted out of api-ssl to avoid router-side config.
    # Switch to api-ssl later by running on each router:
    #   /ip service enable api-ssl ; /ip service disable api
    # and flipping use_ssl=True, no_ssl_certificate=True, plaintext_login=False
    # and port=8729 here.
    use_ssl = False
    no_ssl_certificate = False
    ssl_certificate_verify = False
    ssl_ca_file = ""
    plaintext_login = True

    health = True
    installed_packages = True
    dhcp = True
    dhcp_lease = True

    connections = True
    connection_stats = False

    interface = True

    route = True
    pool = True
    firewall = True
    neighbor = True
    dns = False

    ipv6_route = False
    ipv6_pool = False
    ipv6_firewall = False
    ipv6_neighbor = False

    poe = True
    monitor = True
    netwatch = True
    public_ip = True
    wireless = True
    wireless_clients = True
    capsman = True
    capsman_clients = True

    eoip = False
    gre = False
    ipip = False
    lte = False
    ipsec = False
    switch_port = False
    container = False
    module_only = False
    ssl_check_hostname = False
    w60g = False
    address_list = False
    ipv6_address_list = False
    custom_labels = {}

    kid_control_assigned = False
    kid_control_dynamic = False

    user = True
    queue = True

    bfd = False
    bgp = False
    routing_stats = False
    certificate = False

    remote_dhcp_entry = None
    remote_capsman_entry = None

    interface_name_format = 'comment'
    check_for_updates = False
