---
import { GITHUB_URL, SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} {SITE_TITLE}</span>
	<nav class="links">
		<a href={GITHUB_URL} rel="me noopener" target="_blank">GitHub</a>
		<a href="/rss.xml">RSS</a>
	</nav>
</footer>
<style>
	footer {
		max-width: var(--content-width);
		margin: 3rem auto 0;
		padding: 1.5rem var(--content-pad) 2.5rem;
		color: var(--fg-dim);
		font-size: 0.82rem;
		border-top: 1px solid var(--border);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.links {
		display: flex;
		gap: 1rem;
	}
	.links a {
		color: var(--fg-dim);
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.links a:hover {
		color: var(--accent);
	}
</style>
