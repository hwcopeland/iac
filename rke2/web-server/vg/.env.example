# Secret used to sign our own session + OAuth-state cookies (any long random string).
# Generate one with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string

# Authentik OIDC (the /admin area is gated behind SSO + the VG-Admin group).
# In the cluster these come from the `vg-oidc` Secret (ExternalSecret -> Vaultwarden).
OIDC_ISSUER=https://auth.hwcopeland.net/application/o/vg/
OIDC_CLIENT_ID=vg
OIDC_CLIENT_SECRET=change-me

# Optional overrides:
# OIDC_SCOPES="openid profile email groups"
# ADMIN_GROUP=VG-Admin
# For local development, the redirect URI must match an Authentik redirect URI:
# OIDC_REDIRECT_URI=http://localhost:4321/api/auth/callback

# Where the SQLite database and uploaded images are stored.
# In the cluster this is a mounted PVC; locally it defaults to ./data.
DATA_DIR=./data
