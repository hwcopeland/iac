---
import Admin from '@/layouts/Admin.astro';
import { getTeam } from '@/lib/content';
const team = await getTeam();
---
<Admin title="Team" active="team">
  <datalist id="focuspresets">
    <option value="50% 50%">Center</option>
    <option value="50% 0%">Top / face</option>
    <option value="50% 20%">Upper</option>
    <option value="20% 35%">Left</option>
    <option value="85% 35%">Right</option>
  </datalist>
  <details class="editor">
    <summary>+ Add team member</summary>
    <form method="POST" action="/api/admin/team" enctype="multipart/form-data" style="margin-top:1rem">
      <input type="hidden" name="_action" value="create" />
      <div class="two-col">
        <div class="field"><label>Name</label><input name="name" required /></div>
        <div class="field"><label>Role / credentials</label><input name="role" /></div>
        <div class="field"><label>Tenure</label><input name="tenure" placeholder="e.g. 3 years" /></div>
        <div class="field"><label>Favorite plant</label><input name="favoritePlant" /></div>
      </div>
      <div class="field"><label>Bio</label><textarea name="bio"></textarea></div>
      <div class="two-col">
        <div class="field"><label>Photo (optional)</label><input type="file" name="photo" accept="image/*" /></div>
        <div class="field"><label>Sort order</label><input type="number" name="sortOrder" value="0" /></div>
      </div>
      <div class="field">
        <label>Photo focus</label>
        <input name="photoPosition" list="focuspresets" value="50% 20%" />
        <p class="meta">How the photo is cropped. Format: <code>X% Y%</code>. Lower Y = show higher up (face); X shifts left/right. Try presets ↑</p>
      </div>
      <button class="btn" type="submit">Add member</button>
    </form>
  </details>

  {team.map((m) => (
    <div class="admin-row">
      <div class="grow">
        <strong>{m.name}</strong> <span class="meta">{m.role}</span>
        <details class="editor" style="margin:.6rem 0 0">
          <summary>Edit</summary>
          <form method="POST" action="/api/admin/team" enctype="multipart/form-data" style="margin-top:1rem">
            <input type="hidden" name="_action" value="update" />
            <input type="hidden" name="id" value={m.id} />
            <div class="two-col">
              <div class="field"><label>Name</label><input name="name" value={m.name} required /></div>
              <div class="field"><label>Role / credentials</label><input name="role" value={m.role} /></div>
              <div class="field"><label>Tenure</label><input name="tenure" value={m.tenure} /></div>
              <div class="field"><label>Favorite plant</label><input name="favoritePlant" value={m.favoritePlant} /></div>
            </div>
            <div class="field"><label>Bio</label><textarea name="bio">{m.bio}</textarea></div>
            <div class="two-col">
              <div class="field"><label>Replace photo</label><input type="file" name="photo" accept="image/*" />
                {m.photoUrl && <p class="meta">Current: {m.photoUrl}</p>}</div>
              <div class="field"><label>Sort order</label><input type="number" name="sortOrder" value={m.sortOrder} /></div>
            </div>
            <div class="field">
              <label>Photo focus</label>
              <input name="photoPosition" list="focuspresets" value={m.photoPosition} />
              <p class="meta">Crop position <code>X% Y%</code> — lower Y shows higher up; X shifts left/right.</p>
            </div>
            <button class="btn btn--sm" type="submit">Save changes</button>
          </form>
        </details>
      </div>
      <form method="POST" action="/api/admin/team" class="admin-actions"
            onsubmit="return confirm('Delete this team member?')">
        <input type="hidden" name="_action" value="delete" />
        <input type="hidden" name="id" value={m.id} />
        <button class="btn btn--sm btn--danger" type="submit">Delete</button>
      </form>
    </div>
  ))}
</Admin>
