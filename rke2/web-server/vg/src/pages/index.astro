---
import Base from '@/layouts/Base.astro';
import { getSettings, getTestimonials } from '@/lib/content';
const s = await getSettings();
const testimonials = await getTestimonials();
---
<Base title="Home">
  <section class="hero">
    <div class="container">
      <p class="eyebrow" style="color: var(--green-100)">{s.tagline}</p>
      <h1>{s.heroHeading}</h1>
      <p class="lead">{s.heroSubheading}</p>
      <div class="hero-actions">
        <a class="btn" href="/gallery">See what's growing</a>
        <a class="btn btn--ghost" href="/contact">Visit us</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Murfreesboro, Tennessee</p>
      <h2>Local plants, grown with care</h2>
      <p class="lead">{s.homeIntro}</p>
      <div class="hero-actions">
        <a class="btn btn--ghost" href="/about">Our story</a>
        <a class="btn btn--ghost" href="/team">Meet the team</a>
      </div>
    </div>
  </section>

  {testimonials.length > 0 && (
    <section class="section section--tint">
      <div class="container">
        <p class="eyebrow">Kind words</p>
        <h2>What our customers say</h2>
        <div class="grid grid--3" style="margin-top: 1.5rem">
          {testimonials.map((t) => (
            <blockquote class="card testimonial">
              “{t.quote}”
              {t.author && <cite>— {t.author}</cite>}
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container info-grid">
      <div>
        <h3>Hours</h3>
        <div class="hours-row"><span>Mon – Fri</span><span>{s.hoursWeekday}</span></div>
        <div class="hours-row"><span>Saturday</span><span>{s.hoursSaturday}</span></div>
        <div class="hours-row"><span>Sunday</span><span>{s.hoursSunday}</span></div>
      </div>
      <div>
        <h3>Find us</h3>
        <p>{s.address}</p>
        <p><a href={`tel:${s.phone.replace(/[^0-9+]/g, '')}`}>{s.phone}</a></p>
      </div>
      <div>
        <h3>Get in touch</h3>
        <p>Questions about availability or bulk orders? We'd love to hear from you.</p>
        <a class="btn btn--sm" href="/contact">Contact us</a>
      </div>
    </div>
  </section>
</Base>
