---
import Base from '@/layouts/Base.astro';
import { getTeam } from '@/lib/content';
const team = await getTeam();
const initials = (name: string) =>
  name.split(/\s+/).slice(0, 2).map((w) => w[0]?.toUpperCase()).join('');
---
<Base title="Team" description="Meet the knowledgeable, friendly team at Valley Growers.">
  <section class="hero" style="padding-block: clamp(2.5rem,6vw,4rem)">
    <div class="container">
      <p class="eyebrow" style="color: var(--green-100)">Our people</p>
      <h1>Meet the team</h1>
      <p class="lead">Knowledgeable, friendly, and always happy to help your garden thrive.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="team-grid">
        {team.map((m) => (
          <article class="team-card">
            {m.photoUrl
              ? <img class="team-photo" src={m.photoUrl} alt={m.name} width="300" height="400" loading="lazy" style={`object-position:${m.photoPosition || '50% 20%'}`} />
              : <div class="team-photo team-initials" aria-hidden="true">{initials(m.name)}</div>}
            <div class="team-body">
              <h3>{m.name}</h3>
              {m.role && <div class="role">{m.role}</div>}
              {(m.tenure || m.favoritePlant) && (
                <p class="meta">
                  {[m.tenure, m.favoritePlant && `Favorite: ${m.favoritePlant}`].filter(Boolean).join(' · ')}
                </p>
              )}
              {m.bio && <p>{m.bio}</p>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>
