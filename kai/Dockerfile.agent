# kai-agent Dockerfile
#
# Base: ubuntu:24.04 — provides bash, curl, git, and Python 3 as required by
# docs/spec/kai-plan.md OQ-6 (Phase 1 minimum agent image contents).
#
# The agent entrypoint is a bash script injected at build time.
# Phase 2 will replace entrypoint.sh with real LLM integration logic.
#
# Build context: repo root (.)
#   COPY paths are relative to the repo root.

FROM ubuntu:24.04

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        curl \
        git \
        python3 \
        python3-pip \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY kai/agent/ /agent/
RUN chmod +x /agent/entrypoint.sh

ENTRYPOINT ["/agent/entrypoint.sh"]
