# kai-agent Dockerfile — Phase 2
#
# Multi-stage build:
#   Stage 1 (go-builder): compiles cmd/kai-agent into a static binary.
#   Stage 2 (runtime):    ubuntu:24.04 — retains bash, curl, git, and Python 3
#                         per docs/spec/kai-plan.md OQ-6.  The compiled binary
#                         replaces the Phase 1 entrypoint.sh stub.
#
# Build context: repo root (.)
#   COPY paths are relative to the repo root.


# ── Stage 1: Build the Go agent binary ────────────────────────────────────────
FROM golang:1.25-alpine AS go-builder

WORKDIR /app

# Layer-cache Go module downloads separately from source.
COPY kai/go.mod kai/go.sum ./
RUN go mod download

# Copy all kai source files.
COPY kai/ ./

RUN go build -o /kai-agent ./cmd/kai-agent/


# ── Stage 2: Runtime image ────────────────────────────────────────────────────
FROM ubuntu:24.04

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        curl \
        git \
        python3 \
        python3-pip \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY --from=go-builder /kai-agent /kai-agent

ENTRYPOINT ["/kai-agent"]
